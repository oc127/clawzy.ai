{
  "expo": {
    "name": "NipponClaw",
    "slug": "nipponclaw",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nipponclaw",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nipponclaw.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.nipponclaw.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
