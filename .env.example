# =============================================================================
# Clawzy.ai — Environment Variables
# Copy to .env and fill in your actual values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=change_me_pg_password_2024

# --- LiteLLM Proxy ---
# Master key for LiteLLM admin API (generate: openssl rand -hex 16)
LITELLM_MASTER_KEY=sk-clawzy-change-me
# Salt key for encrypting stored API keys (generate: openssl rand -hex 16)
# WARNING: cannot be changed after models are added
LITELLM_SALT_KEY=salt-clawzy-change-me

# --- Model Provider API Keys ---
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# Alibaba DashScope (Qwen): https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# --- Clawzy Backend ---
# JWT secret for auth tokens (generate: openssl rand -hex 32)
JWT_SECRET=change-me-jwt-secret

# --- Stripe (optional for MVP) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs (create in Stripe Dashboard → Products)
# STRIPE_PRICE_STARTER=price_xxx    # Starter plan $9/mo
# STRIPE_PRICE_PRO=price_xxx        # Pro plan $19/mo
# STRIPE_PRICE_BUSINESS=price_xxx   # Business plan $39/mo

# --- Frontend (Next.js) ---
# These must start with NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_API_URL=https://clawzy.ai/api/v1
NEXT_PUBLIC_WS_URL=wss://clawzy.ai/api/v1
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_starter_monthly
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_pro_monthly
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=price_business_monthly

# --- OpenClaw ---
# Gateway token (generate: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=change-me-openclaw-gateway-token
# Optional: override OpenClaw image
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# --- Self-Healing & Monitoring ---
# Admin API key for ops endpoints (generate: openssl rand -hex 16)
ADMIN_API_KEY=
# Webhook URL for alerts (Slack incoming webhook / Discord webhook)
ALERT_WEBHOOK_URL=

# --- Email (SMTP) ---
# For password reset and email verification
SMTP_HOST=                    # e.g. smtp.gmail.com, smtp.resend.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@clawzy.ai
APP_URL=https://clawzy.ai     # Used for email links

# --- Sentry (Error Tracking) ---
SENTRY_DSN=                   # https://xxx@sentry.io/yyy

# --- Telegram (Ops Agent) ---
# Create bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Backup (OSS — S3 兼容 API) ---
# Alibaba Cloud OSS for off-site database backups (no ossutil64 needed)
# Uses S3-compatible Signature V4 — only curl + openssl required
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com   # Region endpoint
OSS_BUCKET=                                      # Bucket name
OSS_ACCESS_KEY_ID=                               # AccessKey ID
OSS_ACCESS_KEY_SECRET=                           # AccessKey Secret
OSS_PREFIX=backups/                              # Object key prefix
OSS_RETENTION_DAYS=30                            # Auto-delete after N days
