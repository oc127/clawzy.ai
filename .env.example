# =============================================================================
# Clawzy.ai — Environment Variables
# Copy to .env and fill in your actual values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=change_me_pg_password_2024

# --- LiteLLM Proxy ---
# Master key for LiteLLM admin API (generate: openssl rand -hex 16)
LITELLM_MASTER_KEY=sk-clawzy-change-me
# Salt key for encrypting stored API keys (generate: openssl rand -hex 16)
# WARNING: cannot be changed after models are added
LITELLM_SALT_KEY=salt-clawzy-change-me

# --- Model Provider API Keys ---
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# Alibaba DashScope (Qwen): https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# --- Clawzy Backend ---
# JWT secret for auth tokens (REQUIRED — generate: openssl rand -hex 32)
JWT_SECRET=

# --- Stripe (optional for MVP) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- OAuth (optional — enable social login) ---
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Base URL for OAuth redirects (e.g. https://clawzy.ai)
OAUTH_REDIRECT_BASE_URL=

# --- OpenClaw ---
# Gateway token — used for both the OpenClaw Gateway container auth
# and the backend's access to the Gateway API (generate: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=change-me-openclaw-gateway-token
# Optional: override OpenClaw image
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
